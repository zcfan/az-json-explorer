{
  "manifest_version": 3,
  "name": "AZ JSON Explorer",
  "description": "View, format, search, and browse large JSON. Parse nested JSON strings into expandable trees with one click.",
  "version": "0.1.5",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "AZ JSON Explorer",
    "default_popup": "src/popup.html"
  },
  "options_page": "src/viewer.html",
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "externally_connectable": {
    "ids": [
      "*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*"
      ],
      "js": [
        "src/contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/viewer.html",
        "src/viewer.js",
        "src/core/*.js",
        "src/ui/*.js",
        "src/worker/*.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
